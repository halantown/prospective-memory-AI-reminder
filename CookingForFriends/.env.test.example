# Test / pilot / thesis-screenshot environment.
# Copy this file to .env.test:
#   cp .env.test.example .env.test

# PostgreSQL
POSTGRES_DB=cooking_for_friends
POSTGRES_USER=cff
POSTGRES_PASSWORD=cff_dev_pass
POSTGRES_PORT=5432

# Backend database URL
DATABASE_URL=postgresql+asyncpg://cff:cff_dev_pass@localhost:5432/cooking_for_friends

# Backend
ENVIRONMENT=test
HOST=0.0.0.0
PORT=5000
DATA_DIR=
MESSAGE_COOLDOWN_S=10

# Test hooks
DEV_TOKEN=ABC123

# Security
# Kept relaxed for controlled local/pilot testing and screenshots.
CORS_ORIGINS=*
ADMIN_API_KEY=
