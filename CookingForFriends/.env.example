# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=cooking_for_friends
POSTGRES_USER=cff
POSTGRES_PASSWORD=cff_dev_pass
POSTGRES_PORT=5432

# Composed DATABASE_URL used by the backend
DATABASE_URL=postgresql+asyncpg://cff:cff_dev_pass@localhost:5432/cooking_for_friends

# ── Backend ────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
DATA_DIR=
DEV_TOKEN=ABC123
MESSAGE_COOLDOWN_S=10

# ── Security ──────────────────────────────────────────
# Comma-separated allowed origins (use "*" for development only)
CORS_ORIGINS=*
# API key required for /api/admin/* endpoints (leave empty to disable in dev)
ADMIN_API_KEY=

# ── Environment ────────────────────────────────────────
ENVIRONMENT=development
