# Choose an environment-specific template instead of copying this file:
#
# Development / screenshots:
#   cp .env.development.example .env.development
#   python backend/main.py --env development
#
# Test / pilot:
#   cp .env.test.example .env.test
#   python backend/main.py --env test
#
# Production:
#   cp .env.production.example .env.production
#   python backend/main.py --env production
#
# Production must set ENVIRONMENT=production, a non-empty ADMIN_API_KEY,
# explicit CORS_ORIGINS, and no DEV_TOKEN.
