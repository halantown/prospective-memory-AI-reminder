# Development environment template.
# Runtime uses .env.development by default.

# PostgreSQL
POSTGRES_DB=cooking_for_friends
POSTGRES_USER=cff
POSTGRES_PASSWORD=cff_dev_pass
POSTGRES_PORT=5432

# Backend database URL
DATABASE_URL=postgresql+asyncpg://cff:cff_dev_pass@localhost:5432/cooking_for_friends

# Backend
ENVIRONMENT=development
HOST=0.0.0.0
PORT=5000
DATA_DIR=
MESSAGE_COOLDOWN_S=10

# Development/test hooks
# Reusable participant token for screenshots and local smoke tests.
DEV_TOKEN=ABC123

# Security
# Wildcard CORS and empty admin key are allowed only in development/test.
CORS_ORIGINS=*
ADMIN_API_KEY=
