  "focality_scoring": {
    "description": "How to calculate focality score",
    "high_focal": {
      "score_range": [0.7, 1.0],
      "characteristics": [
        "Direct semantic overlap between ongoing task and PM task",
        "Visual or contextual cue present in ongoing task",
        "Triggers spontaneous retrieval (PAM theory)"
      ]
    },
    "low_focal": {
      "score_range": [0.0, 0.3],
      "characteristics": [
        "No semantic relationship",
        "Pure time-based trigger",
        "Requires active monitoring (PAM theory)"
      ]
    }
  }
